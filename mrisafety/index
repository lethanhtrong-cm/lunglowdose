</head>
<body class="bg-gray-100 font-sans leading-relaxed">

    <!-- Container chính -->
    <div class="max-w-6xl mx-auto p-4 md:p-8">

        <!-- Header -->
        <header class="mb-6 pb-4 border-b border-gray-300">
            <h1 class="text-3xl md:text-4xl font-bold text-mri-blue">Cẩm Nang An Toàn MRI</h1>
            <p class="text-lg text-gray-600">Dành cho Kỹ thuật viên Hình ảnh Y học</p>
        </header>

        <!-- Tuyên bố miễn trừ trách nhiệm QUAN TRỌNG -->
        <div class="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4 rounded-md mb-6" role="alert">
            <p class="font-bold">Lưu ý Quan Trọng</p>
            <p>Thông tin trên trang này chỉ mang tính chất tham khảo, học tập. Luôn tuân thủ tuyệt đối quy trình an toàn, quy định của Bệnh viện và hướng dẫn từ nhà sản xuất thiết bị.</p>
        </div>

        <!-- Thanh điều hướng Tabs -->
        <nav class="bg-white shadow-md rounded-lg mb-6 sticky top-0 z-10">
            <ul class="flex flex-wrap border-b border-gray-200">
                <!-- Các nút tab -->
                <li><button class="tab-button p-4 text-gray-600 hover:bg-gray-50 border-b-4 border-transparent" onclick="openTab(event, 'tab-home')">Trang chủ</button></li>
                <li><button class="tab-button p-4 text-gray-600 hover:bg-gray-50 border-b-4 border-transparent" onclick="openTab(event, 'tab-b0')">Từ Trường Tĩnh (B₀)</button></li>
                <li><button class="tab-button p-4 text-gray-600 hover:bg-gray-50 border-b-4 border-transparent" onclick="openTab(event, 'tab-gradient')">Trường Gradient</button></li>
                <li><button class="tab-button p-4 text-gray-600 hover:bg-gray-50 border-b-4 border-transparent" onclick="openTab(event, 'tab-rf')">Sóng RF (B₁)</button></li>
                <li><button class="tab-button p-4 text-gray-600 hover:bg-gray-50 border-b-4 border-transparent" onclick="openTab(event, 'tab-safety')">Quy Trình An Toàn</button></li>
            </ul>
        </nav>

        <!-- Nội dung các Tabs -->
        <main>
            <!-- Tab 1: Trang chủ (Tổng quan) -->
            <div id="tab-home" class="tab-content">
                <h2 class="text-2xl font-bold text-mri-blue mb-4">Chào mừng đến với Cẩm Nang An Toàn MRI</h2>
                <p class="mb-6">Mục tiêu của trang web này là cung cấp một công cụ tra cứu nhanh chóng, đáng tin cậy về các nguyên tắc vật lý và quy trình an toàn cốt lõi trong vận hành máy MRI. Hãy chọn một chủ đề từ thanh điều hướng để bắt đầu.</p>
                
                <h3 class="text-xl font-semibold text-gray-800 mb-4">Truy Cập Nhanh Các Quy Trình</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <!-- Nút Sàng lọc -->
                    <a href="#" onclick="openTab(event, 'tab-safety', 'section-screening')" class="bg-mri-accent hover:bg-opacity-90 text-white font-bold p-6 rounded-lg shadow-lg transition duration-300 flex flex-col items-center justify-center text-center">
                        <i data-lucide="clipboard-check" class="w-10 h-10 mb-2"></i>
                        <span>Sàng Lọc Bệnh Nhân</span>
                    </a>
                    <!-- Nút Tra cứu Implant -->
                    <a href="#" onclick="openTab(event, 'tab-safety', 'section-implant')" class="bg-mri-warn hover:bg-opacity-90 text-mri-blue font-bold p-6 rounded-lg shadow-lg transition duration-300 flex flex-col items-center justify-center text-center">
                        <i data-lucide="heart-pulse" class="w-10 h-10 mb-2"></i>
                        <span>An Toàn Implant</span>
                    </a>
                    <!-- Nút Khẩn cấp -->
                    <a href="#" onclick="openTab(event, 'tab-safety', 'section-emergency')" class="bg-mri-danger hover:bg-opacity-90 text-white font-bold p-6 rounded-lg shadow-lg transition duration-300 flex flex-col items-center justify-center text-center">
                        <i data-lucide="siren" class="w-10 h-10 mb-2"></i>
                        <span>Xử Lý Khẩn Cấp</span>
                    </a>
                    <!-- Nút Thuốc Tương Phản -->
                    <a href="#" onclick="openTab(event, 'tab-safety', 'section-contrast')" class="bg-mri-safe hover:bg-opacity-90 text-white font-bold p-6 rounded-lg shadow-lg transition duration-300 flex flex-col items-center justify-center text-center">
                        <i data-lucide="beaker" class="w-10 h-10 mb-2"></i>
                        <span>An Toàn Thuốc Tương Phản</span>
                    </a>
                </div>
            </div>

            <!-- Tab 2: Từ Trường Tĩnh (B₀) -->
            <div id="tab-b0" class="tab-content bg-red-50 p-1 rounded-lg">
                <div class="bg-white rounded-lg shadow-xl p-6 md:p-8">
                    <h2 class="text-3xl font-bold text-mri-danger mb-4 flex items-center">
                        <i data-lucide="magnet" class="w-8 h-8 mr-3"></i>
                        An Toàn Từ Trường Tĩnh (B₀)
                    </h2>
                    <p class="text-lg mb-4">Đây là từ trường chính của máy, **LUÔN LUÔN BẬT** (ngay cả khi không quét). Đây là mối nguy hiểm lớn nhất và tức thời nhất trong phòng MRI.</p>

                    <hr class="my-6">

                    <!-- Hiệu ứng đạn bắn -->
                    <div class="bg-red-50 border-l-4 border-mri-danger rounded-md p-6 mb-6">
                        <h3 class="text-xl font-bold text-mri-danger mb-2 flex items-center">
                            <i data-lucide="shield-alert" class="w-6 h-6 mr-2"></i>
                            NGUY HIỂM: Hiệu Ứng Đạn Bắn (Projectile Effect)
                        </h3>
                        <p class="text-gray-800 mb-2">Từ trường tĩnh tạo ra lực hút cực mạnh (lực tịnh tiến) lên các vật liệu **sắt từ** (ferromagnetic) như sắt, thép, niken.</p>
                        <ul class="list-disc list-inside space-y-1">
                            <li>Các vật thể (bình oxy, xe đẩy, ghế, kẹp tóc...) có thể bị hút vào lồng máy với tốc độ cực lớn, gây nguy hiểm chết người cho bất kỳ ai trên đường đi.</li>
                            <li>Lực hút tăng theo cấp số nhân khi lại gần lồng máy.</li>
                        </ul>
                        <p class="font-bold mt-4">PHÒNG NGỪA: KHÔNG BAO GIỜ mang vật thể sắt từ vào Vùng IV (Phòng Máy).</p>
                    </div>

                    <!-- Lực xoắn -->
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Lực Xoắn (Torque)</h3>
                    <p class="mb-4">Các vật kim loại bên trong cơ thể (ví dụ: kẹp phình mạch cũ, mảnh kim loại) có thể bị xoắn hoặc dịch chuyển, gây tổn thương mô nghiêm trọng. Đây là lý do cốt lõi của việc sàng lọc implant.</p>

                    <!-- Từ trường ngoại vi -->
                    <h3 class="text-xl font-semibold text-gray-800 mb-2 mt-6">Từ Trường Ngoại Vi (Fringe Field)</h3>
                    <p class="mb-4">Đây là vùng từ trường B₀ lan ra bên ngoài lồng máy. Ngay cả khi đứng ngoài phòng máy, từ trường vẫn có thể tồn tại và gây nguy hiểm:</p>
                    <ul class="list-disc list-inside space-y-1">
                        <li>Làm hỏng thẻ tín dụng, điện thoại, đồng hồ cơ.</li>
                        <li>Gây ảnh hưởng đến các thiết bị y tế cấy ghép (máy tạo nhịp) của người đứng gần cửa phòng máy.</li>
                        <li>Các máy MRI hiện đại có "chắn từ chủ động" (active shielding) để giảm thiểu từ trường ngoại vi, nhưng KTV luôn phải nhận thức về đường 5 Gauss (0.5 mT).</li>
                    </ul>

                    <!-- Các vùng an toàn -->
                    <h3 class="text-xl font-semibold text-gray-800 mb-2 mt-6">Các Vùng An Toàn MRI (MRI Zones)</h3>
                    <p class="mb-4">Việc phân vùng là nền tảng để kiểm soát B₀:</p>
                    <ul class="space-y-3">
                        <li><strong>Vùng I (Zone I):</strong> Khu vực công cộng (VD: Phòng chờ). Mọi người đều có thể vào.</li>
                        <li><strong>Vùng II (Zone II):</strong> Khu vực chờ, sàng lọc. Bệnh nhân được giám sát. (VD: Phòng thay đồ, phòng phỏng vấn KTV).</li>
                        <li><strong>Vùng III (Zone III):</strong> Khu vực hạn chế, đã được sàng lọc. (VD: Phòng điều khiển). Chỉ nhân viên được đào tạo và bệnh nhân đã sàng lọc mới được vào.</li>
                        <li class="font-bold text-mri-danger"><strong>Vùng IV (Zone IV):</strong> Phòng máy. Đây là nơi có từ trường B₀. Phải được kiểm soát nghiêm ngặt bởi KTV.</li>
                    </ul>
                </div>
            </div>

            <!-- Tab 3: Trường Gradient -->
            <div id="tab-gradient" class="tab-content bg-yellow-50 p-1 rounded-lg">
                <div class="bg-white rounded-lg shadow-xl p-6 md:p-8">
                    <h2 class="text-3xl font-bold text-mri-warn mb-4 flex items-center">
                        <i data-lucide="activity" class="w-8 h-8 mr-3"></i>
                        An Toàn Trường Gradient
                    </h2>
                    <p class="text-lg mb-4">Đây là các từ trường yếu hơn B₀, được bật-tắt rất nhanh (hàng nghìn lần/giây) để mã hóa không gian (xác định vị trí). Chúng chỉ hoạt động khi máy đang **quét**.</p>
                    
                    <hr class="my-6">

                    <!-- Tiếng ồn -->
                    <div class="bg-yellow-50 border-l-4 border-mri-warn rounded-md p-6 mb-6">
                        <h3 class="text-xl font-bold text-mri-warn mb-2 flex items-center">
                            <i data-lucide="volume-2" class="w-6 h-6 mr-2"></i>
                            NGUY HIỂM: Tiếng Ồn (Acoustic Noise)
                        </h3>
                        <p class="text-gray-800 mb-2">Việc bật-tắt nhanh các cuộn gradient gây ra rung động cơ học, tạo ra tiếng ồn rất lớn (có thể > 110 dB), đủ để gây tổn thương thính giác vĩnh viễn.</p>
                        <p class="text-gray-800 mb-2 mt-2"><strong>Yếu tố ảnh hưởng:</strong> Tiếng ồn lớn hơn với: Slew rate cao, FOV nhỏ, Lát cắt mỏng, chuỗi xung EPI/DTI.</p>
                        <p class="font-bold mt-4">PHÒNG NGỪA: BẮT BUỘC cung cấp và hướng dẫn bệnh nhân sử dụng nút tai (earplugs) hoặc tai nghe (headphones) CHUẨN cho mọi cuộc chụp.</p>
                    </div>

                    <!-- Kích thích thần kinh -->
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Kích Thích Thần Kinh Ngoại Vi (PNS)</h3>
                    <p class="mb-4">Trường gradient thay đổi nhanh có thể gây ra dòng điện cảm ứng trong cơ thể (theo Định luật Faraday). Bệnh nhân có thể cảm thấy:</p>
                    <ul class="list-disc list-inside space-y-1">
                        <li>Co giật nhẹ ở cơ.</li>
                        <li>Cảm giác "kiến bò" hoặc "điện giật" nhẹ.</li>
                        <li>Thường gặp ở các chuỗi xung nhanh, mạnh (như EPI, DTI).</li>
                        <li>Vị trí: Thường xảy ra ở ngoại vi (tay, chân) hoặc vùng lưng, nơi cơ thể tạo thành vòng lặp lớn.</li>
                    </ul>
                    <p class="mt-2"><strong>XỬ LÝ:</strong> Đây là hiện tượng không nguy hiểm nhưng gây khó chịu. Cần trấn an bệnh nhân trước khi chụp. Nếu bệnh nhân quá khó chịu, hãy dừng xung và điều chỉnh thông số (nếu có thể).</p>

                    <!-- Dòng điện cảm ứng -->
                    <h3 class="text-xl font-semibold text-gray-800 mb-2 mt-6">Dòng Điện Cảm Ứng (trong dây dẫn)</h3>
                    <p class="mb-4">Gradient cũng có thể tạo dòng điện trong các vòng lặp (loops) của dây dẫn (như dây ECG, dây coil), góp phần gây bỏng (mặc dù RF là nguyên nhân chính).</p>
                </div>
            </div>

            <!-- Tab 4: Sóng RF (B₁) -->
            <div id="tab-rf" class="tab-content bg-orange-50 p-1 rounded-lg">
                <div class="bg-white rounded-lg shadow-xl p-6 md:p-8">
                    <h2 class="text-3xl font-bold text-mri-danger mb-4 flex items-center">
                        <i data-lucide="zap" class="w-8 h-8 mr-3"></i>
                        An Toàn Sóng RF (B₁)
                    </h2>
                    <p class="text-lg mb-4">Đây là sóng vô tuyến (Radiofrequency), được phát vào cơ thể để kích thích các proton. Sóng RF chỉ hoạt động khi máy đang **quét**.</p>
                    
                    <hr class="my-6">

                    <!-- Bỏng do RF -->
                    <div class="bg-red-50 border-l-4 border-mri-danger rounded-md p-6 mb-6">
                        <h3 class="text-xl font-bold text-mri-danger mb-2 flex items-center">
                            <i data-lucide="flame" class="w-6 h-6 mr-2"></i>
                            NGUY HIỂM: Bỏng (Thermal Burns)
                        </h3>
                        <p class="text-gray-800 mb-2">Đây là rủi ro phổ biến nhất gây tổn thương cho bệnh nhân trong MRI. Năng lượng RF bị hấp thụ bởi mô và chuyển thành nhiệt. Nếu nhiệt không được tản đi đủ nhanh, nó sẽ gây bỏng (thường là bỏng độ 2, độ 3).</p>
                        <p class="font-bold mt-4">CÁC NGUYÊN NHÂN CHÍNH GÂY BỎNG:</p>
                        <ul class="list-disc list-outside space-y-2 ml-5 mt-2">
                            <li><strong>Vòng lặp da-chạm-da (Skin-to-skin contact):</strong> Ví dụ, hai đùi chạm nhau, tay chạm vào hông. Dòng điện RF sẽ đi tắt qua điểm tiếp xúc, tập trung năng lượng và gây bỏng.</li>
                            <li><strong>Da-chạm-lồng (Skin-to-bore contact):</strong> Bệnh nhân chạm trực tiếp vào thành lồng máy.</li>
                            <li><strong>Vòng lặp dây dẫn (Cable loops) / Hiệu ứng ăng-ten (Antenna Effect):</strong> Dây coil, dây ECG, dây SpO2 tạo thành vòng kín, hoặc có độ dài không phù hợp, hoạt động như một ăng-ten nhận năng lượng RF và gây bỏng tại điểm tiếp xúc.</li>
                            <li><strong>Hình xăm (Tattoos):</strong> Mực xăm (đặc biệt là màu tối, cũ) có thể chứa oxit sắt, hấp thụ năng lượng RF và nóng lên.</li>
                            <li><strong>Miếng dán y tế (Patches):</strong> Một số miếng dán (như nicotine, Fentanyl) có lớp kim loại.</li>
                        </ul>
                    </div> <!-- <-- TÔI ĐÃ THÊM THẺ DIV ĐÓNG BỊ THIẾU VÀO ĐÂY -->

                    <!-- SAR -->
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Tỷ Lệ Hấp Thụ Riêng (SAR - Specific Absorption Rate)</h3>
                    <p class="mb-4">Đây là đơn vị đo lường lượng năng lượng RF được hấp thụ bởi cơ thể, tính bằng Watt trên kilogram (W/kg). Máy MRI sẽ tính toán và cảnh báo SAR dựa trên cân nặng bệnh nhân và chuỗi xung.</p>
                    <ul class="list-disc list-inside space-y-1">
                        <li><strong>SAR Toàn thân (Global SAR):</strong> Giá trị trung bình trên toàn bộ cơ thể.</li>
                        <li><strong>SAR Cục bộ (Local SAR):</strong> Giá trị tại một vùng mô cụ thể (thường là đầu), có thể cao hơn nhiều so với SAR toàn thân.</li>
                        <li class="mt-2"><strong>Chế độ Thường (Normal Mode):</strong> SAR ≤ 2.0 W/kg (toàn thân). Không gây nguy cơ đáng kể.</li>
                        <li><strong>Chế độ Cấp 2 (Second Level Controlled):</strong> SAR cao, chỉ dùng cho nghiên cứu.</li>
                    </ul>
                    <p class="mt-2"><strong>Lưu ý:</strong> Các chuỗi xung FSE/TSE, chuỗi xung nhanh, nhiều lát, TR ngắn... thường có SAR cao.</p>
                    
                    <!-- Phòng ngừa bỏng -->
                    <h3 class="text-xl font-semibold text-mri-safe mb-2 mt-6">Quy Tắc Vàng Phòng Bỏng</h3>
                    <ul class="list-decimal list-outside space-y-2 ml-5 text-mri-safe font-semibold">
                        <li>Luôn dùng đệm lót (pads) cách ly bệnh nhân với lồng máy (khoảng cách tối thiểu 1-2 cm).</li>
                        <li>Dùng đệm lót chèn vào giữa các vùng da tiếp xúc (khuỷu tay, đùi, đầu gối).</li>
                        <li>KHÔNG BAO GIỜ để dây dẫn tạo thành vòng lặp. Dây phải chạy thẳng ra khỏi lồng máy, không bắt chéo.</li>
                        <li>Luôn kiểm tra và hỏi về hình xăm, miếng dán. Chườm lạnh lên hình xăm lớn nếu cần.</li>
                        <li>Cung cấp bóng bóp khẩn cấp và hướng dẫn bệnh nhân sử dụng ngay khi thấy nóng, rát.</li>
                        <li>Đặc biệt cẩn thận với bệnh nhân gây mê, trẻ em, hoặc người không thể giao tiếp.</li>
                    </ul>
                </div>
            </div>

            <!-- Tab 5: Quy Trình An Toàn -->
            <div id="tab-safety" class="tab-content bg-blue-50 p-1 rounded-lg">
                <!-- Sàng lọc -->
                <div id="section-screening" class="bg-white rounded-lg shadow-xl p-6 md:p-8 mb-6">
                    <h2 class="text-3xl font-bold text-mri-blue mb-4 flex items-center">
                        <i data-lucide="clipboard-check" class="w-8 h-8 mr-3 text-mri-accent"></i>
                        Quy Trình Sàng Lọc Bệnh Nhân
                    </h2>
                    <p class="text-lg mb-4">Sàng lọc là bước quan trọng nhất để ngăn ngừa tai nạn từ B₀ và RF. KTV là người chịu trách nhiệm cuối cùng cho việc này.</p>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Checklist Sàng Lọc Tối Thiểu (Hỏi bệnh nhân):</h3>
                    <ul class="list-disc list-inside space-y-2 text-gray-700">
                        <li>Đã từng phẫu thuật (đặc biệt là não, tim, mắt, tai) chưa?</li>
                        <li>Có bất kỳ thiết bị cấy ghép nào trong người không? (Máy tạo nhịp, ICD, van tim, stent, ốc tai điện tử, bơm tiêm tự động...)</li>
                        <li>Có mảnh kim loại trong người do tai nạn không? (Đạn, mảnh bom, mạt sắt trong mắt...)</li>
                        <li>Có hình xăm hoặc trang điểm vĩnh viễn không?</li>
                        <li>Có đang mang miếng dán y tế không?</li>
                        <li>Có khả năng đang mang thai không? (Hỏi bệnh nhân nữ trong độ tuổi sinh đẻ).</li>
                    </ul>
                    <p class="mt-4"><strong>Hành động:</strong> Nếu câu trả lời là "CÓ" cho bất kỳ mục nào liên quan đến kim loại/thiết bị, KTV PHẢI xác minh implant đó là loại gì (tên, model) và kiểm tra tình trạng an toàn (MR Unsafe, MR Conditional, MR Safe) trước khi cho vào phòng máy.</p>
                </div>

                <!-- Implant -->
                <div id="section-implant" class="bg-white rounded-lg shadow-xl p-6 md:p-8 mb-6">
                    <h2 class="text-3xl font-bold text-mri-blue mb-4 flex items-center">
                        <i data-lucide="heart-pulse" class="w-8 h-8 mr-3 text-mri-warn"></i>
                        An Toàn Thiết Bị Cấy Ghép (Implant)
                    </h2>
                    <p class="text-lg mb-4">Phân loại theo tiêu chuẩn ASTM:</p>
                    <ul class="space-y-3">
                        <li class="flex items-start">
                            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-mri-danger text-white font-bold mr-4 flex-shrink-0">
                                <i data-lucide="x-circle"></i>
                            </span>
                            <div>
                                <strong class="text-mri-danger">MR Unsafe (Không An Toàn)</strong>
                                <p>Chống chỉ định tuyệt đối. Gây nguy hiểm rõ ràng. (VD: Kẹp phình mạch sắt từ cũ, một số van tim cơ học).</p>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-mri-warn text-mri-blue font-bold mr-4 flex-shrink-0">
                                <i data-lucide="alert-triangle"></i>
                            </span>
                            <div>
                                <strong class="text-mri-warn">MR Conditional (An Toàn có Điều Kiện)</strong>
                                <p>An toàn khi tuân thủ ĐÚNG điều kiện của nhà sản xuất. Đây là loại phổ biến nhất hiện nay.</p>
                                <p class="text-sm mt-2"><strong>KTV phải kiểm tra:</strong> Từ trường (1.5T hay 3T?), SAR tối đa, Chế độ quét (Normal/First Level), Thời gian chờ sau cấy ghép...</p>
                                <p class="text-sm font-semibold">VD: Hầu hết máy tạo nhịp, ICD, stent, khớp nhân tạo hiện đại là "Conditional".</p>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-mri-safe text-white font-bold mr-4 flex-shrink-0">
                                <i data-lucide="check-circle"></i>
                            </span>
                            <div>
                                <strong class="text-mri-safe">MR Safe (An Toàn)</strong>
                                <p>Thiết bị không chứa kim loại, không dẫn điện, không gây nguy hiểm. (VD: Nẹp vít bằng Titan tinh khiết, Zirconia).</p>
                            </div>
                        </li>
                    </ul>
                    <p class="mt-4 italic">Luôn tra cứu nguồn tin cậy như <a href="http://www.mrisafety.com" target="_blank" class="text-mri-accent font-semibold hover:underline">MRIsafety.com</a> (của Dr. Shellock) hoặc tài liệu của nhà sản xuất implant.</p>
                </div>

                <!-- Khẩn cấp -->
                <div id="section-emergency" class="bg-white rounded-lg shadow-xl p-6 md:p-8 mb-6">
                    <h2 class="text-3xl font-bold text-mri-blue mb-4 flex items-center">
                        <i data-lucide="siren" class="w-8 h-8 mr-3 text-mri-danger"></i>
                        Quy Trình Khẩn Cấp
                    </h2>
                    
                    <div class="bg-red-50 border-l-4 border-mri-danger rounded-md p-6 mb-6">
                        <h3 class="text-xl font-bold text-mri-danger mb-2">1. Vật Thể Bay (Projectile)</h3>
                        <ul class="list-disc list-inside space-y-1">
                            <li>HÔ TOÁN để mọi người dừng di chuyển.</li>
                            <li>Ấn nút **DỪNG KHẨN CẤP** (Emergency Stop - dừng quét, không phải Quench) nếu bệnh nhân đang quét.</li>
                            <li>Đánh giá tình hình. KHÔNG cố gỡ vật thể nếu đã dính vào máy.</li>
                            <li>Gọi kỹ sư hãng.</li>
                        </ul>
                    </div>
                    
                    <div class="bg-red-50 border-l-4 border-mri-danger rounded-md p-6 mb-6">
                        <h3 class="text-xl font-bold text-mri-danger mb-2">2. Tắt Từ (Quench)</h3>
                        <p class="mb-2">Quench là việc xả khẩn cấp khí Helium lỏng, làm mất từ trường B₀. Đây là hành động cuối cùng, gây tốn kém và nguy hiểm (ngạt khí, bỏng lạnh).</p>
                        <p class="font-bold">CHỈ QUENCH KHI:</p>
                        <ul class="list-disc list-inside space-y-1">
                            <li><strong>HỎA HOẠN</strong> trong phòng máy.</li>
                            <li><strong>MỘT NGƯỜI BỊ KẸT</strong> giữa vật thể kim loại lớn và máy, đe dọa tính mạng.</li>
                        </ul>
                        <p class="mt-2 font-bold">KHÔNG QUENCH khi chỉ có vật thể bay (nhưng không kẹt người).</p>
                    </div>

                    <h3 class="text-xl font-semibold text-gray-800 mb-2">3. Cấp Cứu Bệnh Nhân (Code Blue)</h3>
                    <ul class="list-disc list-inside space-y-1">
                        <li>Đưa bệnh nhân ra khỏi phòng máy (Vùng IV) đến Vùng II hoặc III ngay lập tức.</li>
                        <li>Đội cấp cứu KHÔNG được mang xe đẩy, bình oxy, máy sốc tim... vào Vùng IV.</li>
                        <li>Chỉ sử dụng các thiết bị cấp cứu "MR Safe" hoặc "MR Conditional" nếu bắt buộc phải cấp cứu trong phòng máy (rất hiếm).</li>
                    </ul>
                </div>

                <!-- Thai kỳ -->
                <div id="section-pregnancy" class="bg-white rounded-lg shadow-xl p-6 md:p-8 mb-6">
                    <h2 class="text-3xl font-bold text-mri-blue mb-4 flex items-center">
                        <i data-lucide="baby" class="w-8 h-8 mr-3 text-mri-accent"></i>
                        An Toàn cho Thai Kỳ
                    </h2>
                    <p class="text-lg mb-4">Theo hướng dẫn của ACR (American College of Radiology):</p>
                    <ul class="list-disc list-inside space-y-2 text-gray-700">
                        <li>MRI được coi là an toàn ở mọi giai đoạn của thai kỳ nếu thực sự cần thiết về mặt y khoa (lợi ích > rủi ro).</li>
                        <li>Hiện không có bằng chứng nào cho thấy MRI gây hại cho thai nhi.</li>
                        <li>Tuy nhiên, nên thận trọng, đặc biệt là trong 3 tháng đầu (giai đoạn hình thành cơ quan). Chỉ chụp khi không thể trì hoãn sau sinh.</li>
                        <li><strong>Thuốc tương phản (GBCA):</strong> Rất HẠN CHẾ tiêm cho thai phụ. Gadolinium có thể đi qua nhau thai và tích tụ trong dịch ối. Chỉ tiêm khi lợi ích là tuyệt đối và không còn phương pháp thay thế nào khác.</li>
                    </ul>
                </div>
                
                <!-- Thuốc Tương Phản -->
                <div id="section-contrast" class="bg-white rounded-lg shadow-xl p-6 md:p-8">
                     <h2 class="text-3xl font-bold text-mri-blue mb-4 flex items-center">
                        <i data-lucide="beaker" class="w-8 h-8 mr-3 text-mri-safe"></i>
                        An Toàn Thuốc Tương Phản (GBCA)
                    </h2>
                    <ul class="list-disc list-inside space-y-2">
                        <li><strong>Phản ứng dị ứng:</strong> Luôn chuẩn bị hộp thuốc chống sốc. Theo dõi bệnh nhân 15-30 phút sau tiêm.</li>
                        <li><strong>NSF (Xơ hóa thận hệ thống):</strong> Nguy cơ cao ở bệnh nhân suy thận nặng (eGFR < 30). Luôn kiểm tra eGFR trước khi tiêm thuốc nhóm I (hiện ít dùng) hoặc nhóm III. Thuốc nhóm II (Macrocyclic) được coi là an toàn nhất.</li>
                        <li><strong>Thai kỳ & Cho con bú:</strong> Hạn chế tiêm cho thai phụ. Phụ nữ cho con bú không cần vắt bỏ sữa (theo ACR).</li>
                    </ul>
                </div>

            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer class="text-center p-6 mt-10 border-t border-gray-300">
        <p class="text-sm text-gray-500">Website tham khảo, không thay thế quy trình bệnh viện. Luôn đặt an toàn lên hàng đầu.</p>
    </footer>

    <!-- JavaScript để xử lý Tabs -->
    <script>
        // Kích hoạt các icon Lucide
        // lucide.createIcons(); // <- Đã xóa khỏi đây

        // Hàm mở tab
        function openTab(evt, tabName, sectionId = null) {
            // Lấy tất cả nội dung tab và ẩn đi
            let tabcontent = document.getElementsByClassName("tab-content");
            for (let i = 0; i < tabcontent.length; i++) {
                tabcontent[i].style.display = "none";
            }

            // Lấy tất cả các nút tab và xóa class 'active'
            let tabbuttons = document.getElementsByClassName("tab-button");
            for (let i = 0; i < tabbuttons.length; i++) {
                tabbuttons[i].className = tabbuttons[i].className.replace(" tab-active", "");
            }

            // Hiển thị tab được chọn
            document.getElementById(tabName).style.display = "block";
            
            // Thêm class 'active' cho nút được bấm
            // Nếu bấm từ nút "Truy Cập Nhanh", chúng ta cần tìm nút tab tương ứng
            if (evt.currentTarget.classList.contains('tab-button')) {
                evt.currentTarget.className += " tab-active";
            } else {
                // Tìm nút tab có nội dung tương ứng với tabName
                let buttons = document.querySelectorAll(`.tab-button[onclick*="'${tabName}'"]`);
                if (buttons.length > 0) {
                    buttons[0].className += " tab-active";
                }
            }

            // Cuộn đến section cụ thể nếu được cung cấp (dùng cho Quick Access)
            if (sectionId) {
                // Sử dụng timeout nhỏ để đảm bảo tab đã hiển thị trước khi cuộn
                setTimeout(() => {
                    document.getElementById(sectionId).scrollIntoView({ behavior: 'smooth' });
                }, 100);
            }
        }

        // Mở tab đầu tiên (Trang chủ) làm mặc định
        document.addEventListener('DOMContentLoaded', (event) => {
            // Kích hoạt các icon Lucide sau khi DOM đã tải xong
            lucide.createIcons();
            document.getElementsByClassName('tab-button')[0].click();
        });
    </script>

